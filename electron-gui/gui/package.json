{
  "name": "mcp-workspace-gui",
  "version": "1.0.0",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-builder --dir",
    "prebuild:resources": "node ../scripts/fetch-libreoffice.mjs && node ../scripts/prepare-server-resources.mjs",
    "dist": "npm run prebuild:resources && electron-builder"
  },
  "dependencies": {
    "electron-store": "^10.0.1"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.5",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  },
  "build": {
    "appId": "com.mcp-workspace.gui",
    "productName": "External Workspace for Agents",
    "extraResources": [
      {
        "from": "../build-tmp/server",
        "to": "server"
      },
      {
        "from": "../resources/libreoffice-portable",
        "to": "libreoffice-portable"
      }
    ],
    "win": {
      "target": [
        "dir",
        "zip"
      ],
      "signAndEditExecutable": false
    }
  }
}

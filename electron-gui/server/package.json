    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/turndown": "^5.0.5",
    "tsup": "^8.4.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
